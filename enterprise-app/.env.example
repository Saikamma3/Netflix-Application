# ── Database ─────────────────────────────────────────────────────────
POSTGRES_USER=enterprise
POSTGRES_PASSWORD=changeme
POSTGRES_DB=enterprise_db
DATABASE_URL=postgresql://enterprise:changeme@localhost:5432/enterprise_db

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_PASSWORD=redispass
REDIS_URL=redis://:redispass@localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace-with-256-bit-random-secret
JWT_REFRESH_SECRET=replace-with-another-256-bit-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Services ──────────────────────────────────────────────────────────
API_GATEWAY_PORT=3000
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002

# ── App ───────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
CORS_ORIGINS=http://localhost:5173

# ── Rate Limiting ─────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ── Frontend ──────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3000/api
