# Copy this file to .env and fill in real values before running the app.
# NEVER commit .env to git.

# ── Postgres ──────────────────────────────────────────────────────────
POSTGRES_USER=netflix
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=netflix_db
DATABASE_URL=postgresql://netflix:CHANGE_ME_strong_password@postgres:5432/netflix_db

# ── Redis ──────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_URL=redis://:CHANGE_ME_redis_password@redis:6379

# ── MinIO ─────────────────────────────────────────────────────────────
MINIO_ROOT_USER=CHANGE_ME_minio_user
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=netflix-content
MINIO_ACCESS_KEY=CHANGE_ME_minio_user
MINIO_SECRET_KEY=CHANGE_ME_minio_password

# ── JWT (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_ACCESS_SECRET=CHANGE_ME_64_char_random_hex
JWT_REFRESH_SECRET=CHANGE_ME_64_char_random_hex_different_value
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Service URLs ──────────────────────────────────────────────────────
API_GATEWAY_PORT=3000
AUTH_SERVICE_URL=http://auth-service:3001
CONTENT_SERVICE_URL=http://content-service:3002
USER_SERVICE_URL=http://user-service:3003
STREAMING_SERVICE_URL=http://streaming-service:3004

# ── App ───────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
CORS_ORIGINS=https://yourdomain.com

# ── Rate Limits ───────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200

# ── Frontend ──────────────────────────────────────────────────────────
VITE_API_BASE_URL=/api
VITE_STREAM_BASE_URL=/stream
